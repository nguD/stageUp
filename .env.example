# Clé API Anthropic (https://console.anthropic.com/)
VITE_ANTHROPIC_API_KEY=

# --- Serveur (API + base SQLite) ---
PORT=3001
JWT_SECRET=changez-moi-en-production-minimum-32-caracteres
DATABASE_PATH=./data/journal.db

# 3 comptes stagiaires (créés au 1er démarrage si absents)
STAGIAIRE1_USER=stagiaire1
STAGIAIRE1_PASS=change-me-1
STAGIAIRE1_NAME=Stagiaire 1

STAGIAIRE2_USER=stagiaire2
STAGIAIRE2_PASS=change-me-2
STAGIAIRE2_NAME=Stagiaire 2

STAGIAIRE3_USER=stagiaire3
STAGIAIRE3_PASS=change-me-3
STAGIAIRE3_NAME=Stagiaire 3

# Render : chemin persistant sur disque monté
# DATABASE_PATH=/data/journal.db
